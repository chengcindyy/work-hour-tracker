# 複製為 .env 並填入實際值
# cp .env.example .env

# 資料庫（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/work_hour_tracker

# 推播通知（本地測試用）
# 執行 pnpm run generate-vapid 產生金鑰後填入
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 其他環境變數（依部署需求設定）
# JWT_SECRET=
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# Google OAuth（登入用）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 本地測試 OAuth 時設為 true，停用 dev 自動登入以看到首頁
# DISABLE_DEV_FALLBACK=true
